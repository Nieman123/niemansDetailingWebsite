{
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "cheerio": "^1.1.0",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "sharp": "^0.34.3"
  },
  "scripts": {
    "build:images": "node tools/build-images.mjs",
    "img:rewire": "node scripts/rewire-images.mjs",
    "images:copy": "node scripts/sync-images.mjs",
    "images:sync": "npm run images:copy && npm run build:images && npm run img:rewire",
    "dev:copy": "npm run images:copy",
    "dev:copy:win": "npm run images:copy",
    "build:blog": "node scripts/build-blog.mjs",
    "seed:emulator": "node scripts/seed-emulator-from-prod.mjs",
    "dev:serve": "npx http-server public -p 5173 -c-1",
    "dev": "npm run images:sync && npm run dev:serve",
    "lhci": "lhci autorun --collect.staticDistDir=public --upload.target=filesystem --upload.outputDir=.lighthouseci"
  },
  "overrides": {
    "simple-swizzle": "0.2.2"
  },
  "dependencies": {
    "firebase": "^12.9.0",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.4.0"
  }
}
